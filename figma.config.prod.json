      "packages/ds-healthcare-gov/src/components/*": "@cms/ds-healthcare-gov",
      "packages/ds-medicare-gov/src/components/*": "@cms/ds-medicare-gov"
    },
    "include": [
      "/packages/design-system/src/components/**/*.{tsx,jsx}",
